NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAILS=

# Cloudflare R2 (storage for candidate videos + source mp4)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=editores-soto
R2_PUBLIC_BASE_URL=https://pub-XXXXX.r2.dev

# Public assets
NEXT_PUBLIC_SOURCE_VIDEO_URL=
NEXT_PUBLIC_REFERENCE_CLIP_URL=

# Casting deadline (ISO 8601). If empty, defaults to build time + 24h.
NEXT_PUBLIC_CASTING_DEADLINE=

# Public site URL — used by the Google OAuth redirect.
NEXT_PUBLIC_SITE_URL=https://editores-soto.vercel.app

# Gmail API (sends confirmation email when a candidate submits)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Optional override; defaults to ${NEXT_PUBLIC_SITE_URL}/api/google/callback
GOOGLE_OAUTH_REDIRECT_URI=
GMAIL_SENDER=pyneal.systems@gmail.com
GMAIL_SENDER_NAME=SOTO.IA Casting
